# Copy this file to .env, then replace the placeholder with a Groq API key.
GROQ_API_KEY=your_groq_api_key

# Optional first-choice model override.
GROQ_MODEL=openai/gpt-oss-120b

# Optional comma-separated fallback order. If the first model hits limits or
# capacity, the backend will try the next one automatically.
GROQ_MODEL_PRIORITY=openai/gpt-oss-120b,llama-3.3-70b-versatile,qwen/qwen3.6-27b,qwen/qwen3-32b,openai/gpt-oss-20b

GROQ_MAX_TOKENS=1800
GROQ_REASONING_EFFORT=low

# Comma-separated browser origins allowed to call the backend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
